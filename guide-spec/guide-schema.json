{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "POE Guide Vault Import Format v3",
  "type": "object",
  "required": ["format", "guides"],
  "properties": {
    "format": { "const": "poe-guide-v3" },
    "guides": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/guide" } }
  },
  "additionalProperties": false,
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "strings": { "type": "array", "items": { "type": "string" } },
    "guide": {
      "type": "object",
      "required": ["id", "title", "version", "archetype", "updated", "pob", "source", "pros", "cons", "coreMechanics", "requiredItems", "recommendedItems", "variants", "stages"],
      "properties": {
        "id": { "$ref": "#/$defs/id" }, "title": { "type": "string" }, "version": { "type": "string" }, "archetype": { "type": "string" },
        "updated": { "type": "string", "pattern": "^$|^[0-9]{4}-[0-9]{2}-[0-9]{2}$" }, "pob": { "type": "string" }, "source": { "type": "string" },
        "pros": { "$ref": "#/$defs/strings" }, "cons": { "$ref": "#/$defs/strings" }, "coreMechanics": { "$ref": "#/$defs/strings" },
        "requiredItems": { "$ref": "#/$defs/strings" }, "recommendedItems": { "$ref": "#/$defs/strings" },
        "variants": { "type": "array", "items": { "$ref": "#/$defs/variant" } },
        "stages": { "type": "array", "minItems": 7, "maxItems": 7, "items": { "$ref": "#/$defs/stage" } }
      }, "additionalProperties": false
    },
    "variant": { "type": "object", "required": ["id", "name", "description"], "properties": { "id": { "$ref": "#/$defs/id" }, "name": { "type": "string" }, "description": { "type": "string" } }, "additionalProperties": false },
    "check": { "type": "object", "required": ["id", "text"], "properties": { "id": { "$ref": "#/$defs/id" }, "text": { "type": "string" }, "required": { "type": "boolean" }, "unlockMessage": { "type": "string" } }, "additionalProperties": false },
    "stage": {
      "type": "object",
      "required": ["id", "name", "summary", "goals", "conditions", "skills", "swaps", "gear", "spectres", "warnings", "progression", "sections", "notes"],
      "properties": {
        "id": { "$ref": "#/$defs/id" }, "name": { "enum": ["總覽", "劇情", "初入輿圖", "低預算", "中預算", "高預算", "終局"] }, "summary": { "type": "string" },
        "goals": { "type": "array", "items": { "$ref": "#/$defs/check" } }, "conditions": { "type": "array", "items": { "$ref": "#/$defs/check" } },
        "skills": { "type": "array", "items": { "$ref": "#/$defs/skillGroup" } }, "swaps": { "type": "array", "items": { "$ref": "#/$defs/swap" } },
        "gear": { "type": "array", "items": { "$ref": "#/$defs/gear" } }, "spectres": { "type": "array", "items": { "$ref": "#/$defs/spectre" } },
        "warnings": { "type": "array", "items": { "$ref": "#/$defs/warning" } }, "progression": { "type": "array", "items": { "$ref": "#/$defs/progression" } },
        "sections": { "type": "array", "items": { "$ref": "#/$defs/section" } }, "notes": { "type": "string" }, "image": { "type": "string" }
      }, "additionalProperties": false
    },
    "variantIds": { "type": "array", "items": { "$ref": "#/$defs/id" } },
    "skill": { "type": "object", "required": ["name", "color"], "properties": { "name": { "type": "string" }, "color": { "enum": ["blue", "red", "green"] } }, "additionalProperties": false },
    "skillGroup": { "type": "object", "required": ["id", "slot", "label", "gems"], "properties": { "id": { "$ref": "#/$defs/id" }, "slot": { "type": "string" }, "label": { "type": "string" }, "gems": { "type": "array", "items": { "$ref": "#/$defs/skill" } }, "variantIds": { "$ref": "#/$defs/variantIds" } }, "additionalProperties": false },
    "swap": { "type": "object", "required": ["id", "remove", "add", "when"], "properties": { "id": { "$ref": "#/$defs/id" }, "remove": { "type": "string" }, "add": { "type": "string" }, "when": { "type": "string" }, "variantIds": { "$ref": "#/$defs/variantIds" } }, "additionalProperties": false },
    "gear": { "type": "object", "required": ["slot", "current", "next", "note"], "properties": { "slot": { "type": "string" }, "current": { "type": "string" }, "next": { "type": "string" }, "note": { "type": "string" }, "variantIds": { "$ref": "#/$defs/variantIds" } }, "additionalProperties": false },
    "spectre": { "type": "object", "required": ["id", "name", "count", "role", "acquisition", "replaces"], "properties": { "id": { "$ref": "#/$defs/id" }, "name": { "type": "string" }, "count": { "type": "integer", "minimum": 1 }, "role": { "type": "string" }, "acquisition": { "type": "string" }, "replaces": { "type": "string" }, "variantIds": { "$ref": "#/$defs/variantIds" } }, "additionalProperties": false },
    "warning": { "type": "object", "required": ["id", "severity", "category", "title", "localizedText", "recommendation"], "properties": { "id": { "$ref": "#/$defs/id" }, "severity": { "enum": ["info", "warning", "danger"] }, "category": { "type": "string" }, "title": { "type": "string" }, "localizedText": { "type": "string" }, "recommendation": { "type": "string" }, "sourceText": { "type": "string" } }, "additionalProperties": false },
    "progression": { "type": "object", "required": ["id", "type", "name", "detail"], "properties": { "id": { "$ref": "#/$defs/id" }, "type": { "enum": ["ascendancy", "passive", "anointment", "tattoo"] }, "name": { "type": "string" }, "detail": { "type": "string" } }, "additionalProperties": false },
    "section": { "type": "object", "required": ["id", "type", "title", "content"], "properties": { "id": { "$ref": "#/$defs/id" }, "type": { "enum": ["craft", "map-mods", "mechanic", "faq", "playstyle", "bossing"] }, "title": { "type": "string" }, "content": { "type": "string" } }, "additionalProperties": false }
  }
}
